# Application
APP_ENV=dev
PORT=8080
# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty
# Database
DATABASE_URL=postgresql://postgres.project:[password]@[name]:6543/postgres?sslmode=require
# Supabase
SUPABASE_PROJECT_URL=https://project.supabase.co
SUPABASE_JWT_ISSUER=https://project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
# Redis
REDIS_URL=https://[endpoint].upstash.io
# Google Cloud Platform
GCP_PROJECT_ID=sonnda
GCP_PROJECT_NUMBER=project-number
GCS_BUCKET=bucket-name
GCP_LOCATION=location
GCP_EXTRACT_LABS_PROCESSOR_ID=processor_id
GOOGLE_APPLICATION_CREDENTIALS="/home/usr/to/credentials/sonnda-gcs.json"
GOOGLE_APPLICATION_CREDENTIALS_JSON=JSON

# CORS (opcional)
# Defaults automáticos por ambiente:
# - dev: http://localhost:5173,http://localhost:3000
# - staging: https://app-staging.sonnda.com.br
# - prod: https://app.sonnda.com.br
# Sobrescrever com variáveis se necessário (separado por vírgula):
# CORS_ORIGINS=https://app.sonnda.com.br,https://another-origin.com
# CORS_CREDENTIALS=true (padrão)
# CORS_MAX_AGE=86400 (em segundos)
